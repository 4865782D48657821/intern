COMPOSE_PROJECT_NAME=company-infra

# Public domains
NEXTCLOUD_DOMAIN=cloud.example.com
COLLABORA_DOMAIN=office.example.com
TURN_DOMAIN=turn.example.com
GITEA_DOMAIN=gitea.example.com

# ACME / proxy
ACME_EMAIL=admin@example.com

# Nextcloud
NEXTCLOUD_TRUSTED_DOMAINS=cloud.example.com
NEXTCLOUD_ADMIN_USER=ncadmin
NEXTCLOUD_ADMIN_PASSWORD=change-me
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=change-me
NEXTCLOUD_DATA_DIR=/var/www/html/data
NEXTCLOUD_UPLOAD_LIMIT=10G
NEXTCLOUD_DOMAIN_REGEX=cloud\\.example\\.com

# Collabora
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=change-me

# TURN / coturn
TURN_LISTEN_PORT=3478
TURN_TLS_LISTEN_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
TURN_REALM=example.com
TURN_STATIC_AUTH_SECRET=change-me

# Gitea
GITEA_ROOT_URL=https://gitea.example.com/
GITEA_SSH_DOMAIN=gitea.example.com
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222
GITEA_DB_NAME=gitea
GITEA_DB_USER=gitea
GITEA_DB_PASSWORD=change-me
GITEA_ADMIN_USER=giteaadmin
GITEA_ADMIN_PASSWORD=change-me
GITEA_ADMIN_EMAIL=dev@example.com
GITEA_SECRET_KEY=change-me
GITEA_INTERNAL_TOKEN=change-me
